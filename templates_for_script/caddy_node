$NODE_DOMAIN {
        bind 0.0.0.0
        root * /srv
        file_server

        header {
                -Server
        }
        handle_errors {
                header {
                        -Server
                }
        }
}

# Bridge subscription endpoint
$NODE_DOMAIN/sub/bridge/* {
        reverse_proxy 127.0.0.1:8080

        header {
                -Server
                Access-Control-Allow-Origin *
        }
}
