{
	email your-email@example.com
}

$VLESS_DOMAIN {
	# API requests that don't start with /api/ need rewriting
	@needs_api {
		path /admins* /users* /nodes* /services* /inbounds* /system* /sub* /proxy-pool* /settings*
		not path /api/*
	}
	rewrite @needs_api /api{uri}

	reverse_proxy * 127.0.0.1:8000

	header {
		-Server
	}

	handle_errors {
		header {
			-Server
		}
	}
}
